# Postgres
DATABASE_URL="postgresql://rbac:rbac@localhost:5432/rbac_system"

NODE_ENV="development"

# Comma-separated list of allowed frontend origins for CORS. Required in production.
FRONTEND_ORIGIN="http://localhost:5173"

# Auth - required in production (validated at boot, see src/env.ts)
JWT_SECRET="change-me-to-a-long-random-value-in-production"

# --- AI engine ---
# "anthropic" (for local demo/testing) or "openai-compatible" (point at your
# internal self-hosted OSS model - vLLM, Ollama, TGI, LocalAI all speak this).
LLM_PROVIDER="openai-compatible"

# Used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"

# Used when LLM_PROVIDER=openai-compatible - point at your internal endpoint.
# Nothing here ever leaves your infra.
OPENAI_COMPATIBLE_BASE_URL="http://localhost:8000/v1"
OPENAI_COMPATIBLE_API_KEY="not-needed-for-most-self-hosted-servers"
OPENAI_COMPATIBLE_MODEL="llama-3.1-70b-instruct"

PORT=4000
